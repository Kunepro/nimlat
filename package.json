{
  "name": "my-anime-tracker",
  "private": true,
  "version": "0.0.0",
  "main": "main.js",
  "author": "Nicolò Zanetti",
  "description": "Table to help tracking anime integration in my personal media library.",
  "scripts": {
    "dev": "vite",
    "electron": "tsc main.ts --outDir dist && electron dist/main.js",
    "start": "concurrently \"vite --host\" \"wait-on http://localhost:5173 && npm run electron\"",
    "build": "rimraf dist release && tsc main.ts && vite build",
    "package": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.my-anime-tracker",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "files": [
      "main.js",
      "dist/**/*",
      "icon.ico"
    ],
    "asar": true,
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "main": "main.js"
    }
  },
  "dependencies": {
    "graphql-request": "^7.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.21.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "vite": "^6.2.0",
    "wait-on": "^8.0.2"
  }
}