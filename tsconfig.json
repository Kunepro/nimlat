{
  "compilerOptions": {
    "target": "esnext",
    "useDefineForClassFields": true,
    "module": "esnext",
    "esModuleInterop": true,
    "lib": ["esnext", "dom"],
    "moduleResolution": "node",
    "strict": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "types": ["vite/client", "node"]
  },
  "include": ["src/**/*", "main.ts"]
}